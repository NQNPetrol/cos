# Copiar a .env.testing para ejecutar tests con MySQL (recomendado: evita incompatibilidades con migraciones que usan ENUM/MODIFY).
# Si no existe .env.testing, los tests usan las variables de .env (p. ej. SQLite); algunas migraciones pueden fallar con SQLite.
#
# Antes de correr tests: crear la base de datos en MySQL, p. ej.:
#   mysql -u root -e "CREATE DATABASE IF NOT EXISTS cos_test;"
# o desde phpMyAdmin (WAMP): crear base de datos "cos_test".

APP_ENV=testing
APP_DEBUG=true

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cos_test
DB_USERNAME=root
DB_PASSWORD=

# El resto se hereda de .env o usa valores por defecto de testing.
